<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Factura" pageWidth="612" pageHeight="792" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="0bb810e8-4a85-4672-9c15-07626b7d5727">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="199"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="una_2023_periodo_i"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="fecha1" class="java.lang.String"/>
	<parameter name="fecha2" class="java.lang.String"/>
	<parameter name="proveedor" class="java.lang.Integer"/>
	<queryString>
		<![CDATA[select row_number() over(order by 1) numero, df.n_factura, pr.nombre,round(sum(df.precio*df.cantidad+(df.precio*df.cantidad*df.impuesto/100)),2) total
from  almacen.facturas f 
left join almacen.detalle_facturas df on f.n_factura=df.n_factura
left join almacen.proveedores pr on pr.id=f.id_proveedor
where f.id_proveedor= $P{proveedor}  and f.deleted_at is null and df.deleted_at is null
and fecha_libros between  $P{fecha1}::date  and  $P{fecha2}::date 
group by pr.nombre,df.n_factura]]>
	</queryString>
	<field name="numero" class="java.lang.Long">
		<property name="com.jaspersoft.studio.field.label" value="numero"/>
	</field>
	<field name="n_factura" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="n_factura"/>
	</field>
	<field name="nombre" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="nombre"/>
	</field>
	<field name="total" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.label" value="total"/>
	</field>
	<variable name="total_total" class="java.lang.Float" calculation="Sum">
		<variableExpression><![CDATA[$F{total}]]></variableExpression>
	</variable>
